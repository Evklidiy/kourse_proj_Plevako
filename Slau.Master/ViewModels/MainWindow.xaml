<Window x:Class="Slau.Master.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Курсовой проект: Распределенная СЛАУ (ИТП-31)" Height="550" Width="850" Background="#F0F0F0">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель управления -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Настройки системы" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Размерность (N):" Margin="0,5,0,0"/>
            <TextBox Name="TxtN" Text="1000" Margin="0,5" Padding="5"/>

            <TextBlock Text="Воркеры (IP:Port):" Margin="0,10,0,0"/>
            <TextBox Name="TxtWorkers" Text="127.0.0.1:5000" Margin="0,5" Padding="5" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

            <Separator Margin="0,15"/>

            <TextBlock Text="Источник данных:" FontWeight="SemiBold" Margin="0,5"/>
            <Button Content="Сгенерировать в памяти" Click="BtnGenerate_Click" Margin="0,5" Height="30"/>
            <Button Content="Загрузить из .txt" Click="BtnLoadFile_Click" Margin="0,5" Height="30" Background="#E1F5FE"/>
            <Button Content="Создать тестовый .txt" Click="BtnCreateTestFile_Click" Margin="0,5" Height="30" Background="#FFF9C4"/>

            <Separator Margin="0,15"/>

            <Button Content="ЗАПУСК: РАСПРЕДЕЛЕННЫЙ ГАУСС" Click="BtnDistributed_Click" Height="50" Background="#C8E6C9" FontWeight="Bold" Margin="0,5"/>
            <Button Content="ЗАПУСК: ЛОКАЛЬНЫЙ ГАУСС" Click="BtnLocalGauss_Click" Height="40" Background="#E0E0E0" Margin="0,5"/>
            <Button Content="ЗАПУСК: ЛОКАЛЬНАЯ РЕЛАКСАЦИЯ" Click="BtnLocal_Click" Height="40" Background="#FFCCBC" Margin="0,5"/>
        </StackPanel>

        <!-- Правая панель логов и результатов -->
        <GroupBox Grid.Column="1" Header="Консоль управления и результаты">
            <TextBox Name="TxtLog" IsReadOnly="True" Background="Black" Foreground="LightGreen" 
                     FontFamily="Consolas" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        </GroupBox>
    </Grid>
</Window>